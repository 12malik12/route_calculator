{
  "name": "trucklogix",
  "version": "1.0.0",
  "description": "TruckLogix - trip planner with FMCSA ELD logs (Django + React)",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "bash scripts/run-backend.sh",
    "dev:frontend": "cd frontend && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "leaflet": "^1.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "vite": "^8.0.16"
  }
}
